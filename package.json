{
  "name": "@serpcheap/next",
  "version": "0.1.0",
  "description": "Next.js helpers for the serp.cheap SERP API — server-side key handling, result caching via unstable_cache with per-query tags, Server Actions, and App Router route handlers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./route": {
      "types": "./dist/route.d.ts",
      "import": "./dist/route.js"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p .",
    "prepare": "tsc -p .",
    "typecheck": "tsc --noEmit",
    "test": "node --conditions=react-server --import tsx --test --experimental-test-coverage --test-coverage-lines=0.95 --test-coverage-branches=0.90 --test-coverage-functions=0.95 --test-coverage-exclude='test/**' test/*.test.ts"
  },
  "keywords": [
    "serp",
    "google",
    "search",
    "nextjs",
    "next",
    "app-router",
    "serpapi"
  ],
  "homepage": "https://serp.cheap",
  "repository": {
    "type": "git",
    "url": "https://github.com/SerpCheap/serpcheap-next.git"
  },
  "license": "MIT",
  "dependencies": {
    "@serpcheap/sdk": "^0.2.0",
    "server-only": "^0.0.1"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
